    RowBox[{"Kp", "\[Rule]", 
     FractionBox[
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["w0", "2"]}], "+", 
       SuperscriptBox["w0cl", "2"], "+", 
       RowBox[{"2", " ", "w0cl", " ", "wmcl"}]}], 
      RowBox[{"Ks", " ", 
       SuperscriptBox["w0", "2"]}]]}], ",", 
    RowBox[{"Ki", "\[Rule]", 
