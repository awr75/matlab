      RowBox[{"KS", " ", 
       SuperscriptBox["omega0", "2"]}]]}]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{
  3.985605317347084*^9, {3.9856053796312428`*^9, 3.9856054224264126`*^9}, 
   3.9856056324761753`*^9, 3.9856110898199863`*^9, 3.9862551466664143`*^9, {
   3.9866011505741863`*^9, 3.986601159357727*^9}, 3.9866933826046696`*^9},
 CellLabel->"Out[9]=",ExpressionUUID->"7e7af160-7f8b-9a48-b8ac-3bc431a37373"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GV", "=", 
  RowBox[{
   RowBox[{"omegaCL", "^", "2"}], "/", 
   RowBox[{"Numerator", "[", "GCL", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9856058350344124`*^9, 3.9856058941323414`*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"ebe5aaa8-b890-de4f-b8de-22362d348e3f"],

Cell[BoxData[
 FractionBox[
  SuperscriptBox["omegaCL", "2"], 
  RowBox[{"KS", " ", 
   SuperscriptBox["omega0", "2"], " ", 
   RowBox[{"(", 
    RowBox[{"Kp", "+", 
