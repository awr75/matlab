Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"2", "*", "w0cl"}], "+", "wmcl"}], "==", 
     RowBox[{
      RowBox[{"2", "*", "D", "*", "w0"}], "+", 
      RowBox[{"Ks", "*", "Kd", "*", 
       RowBox[{"w0", "^", "2"}]}]}]}], " ", "&&", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"w0cl", "^", "2"}], "+", 
      RowBox[{"2", "*", "w0cl", "*", "wmcl"}]}], "==", 
     RowBox[{
      RowBox[{"w0", "^", "2"}], "+", 
      RowBox[{"Kp", "*", "Ks", "*", 
       RowBox[{"w0", "^", "2"}]}]}]}], " ", "&&", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"w0cl", "^", "2"}], "*", "wmcl"}], "==", 
     RowBox[{"Ki", "*", "Ks", "*", 
      RowBox[{"w0", "^", "2"}]}]}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"Kp", ",", "Ki", ",", "Kd"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.986695674086443*^9, 3.9866958515293446`*^9}, {
   3.986695902621603*^9, 3.986695972523508*^9}, {3.9866980207462864`*^9, 
