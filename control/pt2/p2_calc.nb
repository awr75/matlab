Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Kp", "\[Rule]", 
     FractionBox[
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["omega0", "2"]}], "+", 
       SuperscriptBox["omega0CL", "2"]}], 
      RowBox[{"KS", " ", 
       SuperscriptBox["omega0", "2"]}]]}], ",", 
    RowBox[{"Kd", "\[Rule]", 
     RowBox[{"-", 
      FractionBox[
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"D", " ", "omega0"}], "-", 
          RowBox[{"DCL", " ", "omega0CL"}]}], ")"}]}], 
