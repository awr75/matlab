Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Sol", "=", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"CoeffGCL0", "==", 
      RowBox[{"omega0CL", "^", "2"}]}], "&&", 
     RowBox[{"CoeffGCL1", "==", 
      RowBox[{"2", "*", "DCL", "*", "omega0CL"}]}]}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"Kp", ",", "Kd"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9856051964035187`*^9, 3.98560522298678*^9}, {
